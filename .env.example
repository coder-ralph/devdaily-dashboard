# GitHub Personal Access Token (optional but recommended to avoid rate limits)
# Create at: https://github.com/settings/tokens
# Required scopes: public_repo, read:user
VITE_GITHUB_TOKEN=your_github_personal_access_token_here

# Default GitHub username to load on startup (optional)
VITE_DEFAULT_GITHUB_USERNAME=your_github_username_here

# WakaTime API Key (optional — shows mock data if absent)
# Find at: https://wakatime.com/settings/api-key
# NOTE: WakaTime's API blocks browser requests (CORS).
# Without a serverless proxy, this key is used for direct requests
# which may fail in production. See src/services/wakatimeApi.js for
# the Vercel serverless proxy setup instructions.
VITE_WAKATIME_API_KEY=your_wakatime_api_key_here
