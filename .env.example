# DevDaily Dashboard environment variables

# --------------------------------------------------
# GitHub (client-side)
# --------------------------------------------------
# Optional GitHub Personal Access Token to increase API rate limits.
# Without a token, GitHub REST API is limited to 60 requests/hour.
# With a token, the limit increases to 5,000 requests/hour.
#
# The dashboard can also use a token saved directly in the UI
# (stored in browser localStorage).
#
# Create a token at:
# https://github.com/settings/tokens
#
# Recommended scopes:
# - read:user
# - public repositories are accessible without extra scopes

VITE_GITHUB_TOKEN=

# Default GitHub username loaded on dashboard startup (optional)
VITE_DEFAULT_GITHUB_USERNAME=

# --------------------------------------------------
# WakaTime (server-side proxy)
# --------------------------------------------------
# Live WakaTime data is fetched through the serverless proxy:
#   /api/wakatime
#
# The proxy reads this environment variable on Vercel:
#   WAKATIME_API_KEY
#
# If a user saves their own key in the dashboard UI,
# it will be forwarded to the proxy via request header
# and used instead of this environment variable.
#
# On plain localhost (Vite dev server), the /api/wakatime
# endpoint will not work unless you run the project with
# Vercel local development or provide your own proxy.
#
# If the proxy is unavailable, the widget falls back to mock data.
#
# Find your WakaTime API key at:
# https://wakatime.com/settings/api-key

WAKATIME_API_KEY=